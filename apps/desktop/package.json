{
  "name": "@app/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && cross-env DAEMON_EXTERNAL=1 electron dist/main.js",
    "start": "electron dist/main.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@app/daemon": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0"
  }
}
